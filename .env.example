# === CÓRTEX — copie para .env e preencha. NUNCA versione o .env real ===

# App
APP_ENV=production
APP_SECRET=__gere_um_segredo_forte__
JWT_TTL_MIN=15

# PostgreSQL (imagem TimescaleDB; extensões: timescaledb, pgvector)
POSTGRES_HOST=postgres
POSTGRES_DB=cortex
POSTGRES_USER=cortex_app
POSTGRES_PASSWORD=__senha__
# role separada só p/ ingestão de telemetria (insert-only)
POSTGRES_INGEST_USER=cortex_ingest
POSTGRES_INGEST_PASSWORD=__senha_ingest__

# Redis
REDIS_URL=redis://redis:6379/0

# IA local
OLLAMA_URL=http://ollama:11434
MODELO_LOCAL=gemma2:9b
# Claude API — opcional, SÓ para tarefas pesadas SEM dado sensível
ANTHROPIC_API_KEY=

# Cloudflare Tunnel
CLOUDFLARE_TUNNEL_TOKEN=__token__
