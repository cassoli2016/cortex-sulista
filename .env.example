# === CÓRTEX — copie para .env e preencha. NUNCA versione o .env real ===

# App
APP_ENV=production
APP_SECRET=__gere_um_segredo_forte__
JWT_TTL_MIN=15

# PostgreSQL (imagem TimescaleDB; extensões: timescaledb, pgvector)
POSTGRES_HOST=postgres
POSTGRES_DB=cortex
POSTGRES_USER=cortex_app
POSTGRES_PASSWORD=__senha__
# role separada só p/ ingestão de telemetria (insert-only)
POSTGRES_INGEST_USER=cortex_ingest
POSTGRES_INGEST_PASSWORD=__senha_ingest__

# Redis
REDIS_URL=redis://redis:6379/0

# IA local
OLLAMA_URL=http://ollama:11434
MODELO_LOCAL=gemma2:9b
# Claude API — opcional, SÓ para tarefas pesadas SEM dado sensível
ANTHROPIC_API_KEY=

# Cloudflare Tunnel
CLOUDFLARE_TUNNEL_TOKEN=__token__

# Notificações push no celular (Web Push / VAPID). Gere um par com:
#   uv run --with pywebpush python -m py_vapid  (ou peça ao assistente)
# Sem estas chaves o recurso fica desligado (sem erro). VAPID_PRIVATE_KEY é SECRETA.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:ti@sulista.com.br
# hora do digest diário (0-23, horário do servidor); padrão 7
PUSH_HORA=7
